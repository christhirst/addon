{
  "manifest_version": 3,
  "name": "URL Parameter Injector",
  "version": "1.1.6",
  "description": "Inject URL parameters, headers, and auto-redirect SAML identity broker pages to the correct IDP.",
  "permissions": [
    "storage",
    "webRequest",
    "webRequestBlocking",
    "declarativeNetRequest"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icons/icon1024.png"
  },
  "background": {
    "scripts": [
      "background.js"
    ]
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "1024": "icons/icon1024.png"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "url-param-injector@example.com",
      "strict_min_version": "128.0",
      "data_collection_permissions": {
        "required": [
          "none"
        ]
      }
    }
  }
}