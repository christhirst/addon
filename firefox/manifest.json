{
  "manifest_version": 3,
  "name": "URL Parameter Injector",
  "version": "1.0.1",
  "description": "Automatically append query parameters to matching URLs before the request is made.",
  "permissions": [
    "storage",
    "webRequest",
    "declarativeNetRequest"
  ],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icons/icon1024.png"
  },
  "background": {
    "scripts": ["background.js"]
  },
  "icons": {
    "1024": "icons/icon1024.png"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "url-param-injector@example.com",
      "strict_min_version": "128.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  }
}