{
  "manifest_version": 3,
  "name": "URL Parameter Injector",
  "version": "1.0.0",
  "description": "Automatically append query parameters to matching URLs before the request is made.",
  "permissions": [
    "storage",
    "webRequest",
    "declarativeNetRequest"    
  ],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icons/icon1024.png"
  },
  "background": {
    "scripts": ["background.js"]
  },
  "icons": {
    "1024": "icons/icon1024.png"
  },
  "data_collection_permissions": {
    "can_collect_telemetry": false,
    "can_collect_content": false,
    "can_collect_user_interaction": false,"required": [],
  "optional": []
  },
  "browser_specific_settings": {
  "gecko": {
    "id": "url-param-injector@example.com",
    "strict_min_version": "140.0",
    "data_collection_permissions": {
      "required": ["none"]
    }
  }
}
}